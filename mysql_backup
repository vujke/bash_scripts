#!/bin/bash

#: Title           : Backup all MySQL Databases
#: Date            : 2014 (Updated 2026)
#: Author          : github.com/vujke
#: Version         : 2.2
#: Description     : Backs up all MySQL databases, compresses them, prunes old ones, and emails them.

DATE=$(date +"%d%m%Y%H%M")

MYSQL=/usr/bin/mysql
MYSQLDUMP=/usr/bin/mysqldump
MYSQL_HOST="localhost"
MYSQL_USERNAME="vujke"
MYSQL_PASSWORD=""
BACKUP_DIR="$HOME/mysqldump"
EMAIL="@gmail.com" # Replace with your actual email
TIME=$(date)

# System info gathering
DISTRONAME=$(awk -F 'NAME=' '/^NAME=/{gsub(/"/,"",$2); print $2}' /etc/os-release | head -n1)
DISTROVER=$(awk -F 'VERSION_ID=' '/^VERSION_ID=/{gsub(/"/,"",$2); print $2}' /etc/os-release)
KERNEL_VER=$(hostnamectl | awk '/Kernel:/ {print $3}')
ISA=$(hostnamectl | awk '/Architecture:/ {print $2}')
HOSTNAME=$(hostname)

# Check if database directory exists
[ ! -d "$BACKUP_DIR" ] && mkdir -p "$BACKUP_DIR"

# Delete backups older than 15 days safely
find "$BACKUP_DIR" -type f -name "*.sql.gz" -mtime +15 -exec rm {} \;

# List all databases
LIST_OF_DATABASES=$($MYSQL --host=$MYSQL_HOST --user=$MYSQL_USERNAME -p"$MYSQL_PASSWORD" -e "SHOW DATABASES;" | grep -Ev "(Database|information_schema|performance_schema|sys|mysql|zabbix)")

# Loop through and dump databases
for DATABASE_NAME in $LIST_OF_DATABASES; do
    FILE_PATH="${BACKUP_DIR}/${DATABASE_NAME}_${DATE}.sql"
    
    # Dump the database
    $MYSQLDUMP --host=$MYSQL_HOST --force --opt --user=$MYSQL_USERNAME -p"$MYSQL_PASSWORD" --databases "$DATABASE_NAME" --skip-lock-tables > "$FILE_PATH"
    
    # Compress ONLY this specific database backup immediately
    gzip -q "$FILE_PATH"
done

# Build the attachments array for files created in this specific run
ATTACHMENT=()
for file in "$BACKUP_DIR"/*"$DATE"*.sql.gz; do
    [[ -f "${file}" ]] || continue
    ATTACHMENT+=("-a" "${file}")
done

# Listed order
i=1
DB_LIST_BODY=""

for db in $LIST_OF_DATABASES; do
    DB_LIST_BODY+="$i. $db"$'\n'
    ((i++))
done

# Construct the email body
EMAIL_BODY="List of databases ($(echo "$LIST_OF_DATABASES" | wc -l)):\n\n${DB_LIST_BODY}\n"
EMAIL_BODY+="Sent on $TIME from ${DISTRONAME} v${DISTROVER}; kernel v${KERNEL_VER} @ ${ISA}; hostname: ${HOSTNAME}.\n\n"
EMAIL_BODY+="See attachment below:"

# Send the email
echo -e "$EMAIL_BODY" | s-nail "${ATTACHMENT[@]}" -s "MySQL backup at @${HOSTNAME}" "$EMAIL"
